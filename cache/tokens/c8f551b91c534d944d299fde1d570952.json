u03c4\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03bb\u03ae\u03bc\u03b1\u03c4\u03bf\u03c2\",\n        \"\u0391\u03bd\u03ac\u03bb\u03c5\u03c3\u03b7 \u03c4\u03c9\u03bd \u03ba\u03cd\u03c1\u03b9\u03c9\u03bd \u03b4\u03b7\u03bc\u03bf\u03b3\u03c1\u03b1\u03c6\u03b9\u03ba\u03ce\u03bd \u03c4\u03ac\u03c3\u03b5\u03c9\u03bd \u03ba\u03b1\u03b9 \u03b1\u03b9\u03c4\u03b9\u03ce\u03bd\",\n        \"\u03a0\u03b1\u03c1\u03bf\u03c5\u03c3\u03af\u03b1\u03c3\u03b7 \u03c4\u03c9\u03bd \u03b5\u03c0\u03b9\u03c0\u03c4\u03ce\u03c3\u03b5\u03c9\u03bd \u03c3\u03c4\u03b7\u03bd \u03b5\u03bb\u03bb\u03b7\u03bd\u03b9\u03ba\u03ae \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1 \u03ba\u03b1\u03b9 \u03bf\u03b9\u03ba\u03bf\u03bd\u03bf\u03bc\u03af\u03b1\",\n        \"\u03a3\u03c5\u03b6\u03ae\u03c4\u03b7\u03c3\u03b7 \u03c0\u03b9\u03b8\u03b1\u03bd\u03ce\u03bd \u03bb\u03cd\u03c3\u03b5\u03c9\u03bd \u03ba\u03b1\u03b9 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ce\u03bd\",\n        \"\u03a3\u03c5\u03bc\u03c0\u03ad\u03c1\u03b1\u03c3\u03bc\u03b1 \u03bc\u03b5 \u03ad\u03ba\u03ba\u03bb\u03b7\u03c3\u03b7 \u03b3\u03b9\u03b1 \u03b4\u03c1\u03ac\u03c3\u03b7 \u03ae \u03c0\u03c1\u03bf\u03b2\u03bb\u03b7\u03bc\u03b1\u03c4\u03b9\u03c3\u03bc\u03cc\"\n      ]\n    }\n  ],\n  \"assumptions\": [\n    {\n      \"text\": \"\u03a5\u03c0\u03ac\u03c1\u03c7\u03bf\u03c5\u03bd \u03b1\u03be\u03b9\u03cc\u03c0\u03b9\u03c3\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03b4\u03b9\u03b1\u03b8\u03ad\u03c3\u03b9\u03bc\u03b1 \u03b4\u03b5\u03b4\u03bf\u03bc\u03ad\u03bd\u03b1 \u03b3\u03b9\u03b1 \u03c4\u03b1 \u03b4\u03b7\u03bc\u03bf\u03b3\u03c1\u03b1\u03c6\u03b9\u03ba\u03ac \u03c3\u03c4\u03bf\u03b9\u03c7\u03b5\u03af\u03b1 \u03c4\u03b7\u03c2 \u0395\u03bb\u03bb\u03ac\u03b4\u03b1\u03c2 \u03b1\u03c0\u03cc \u03b5\u03c0\u03af\u03c3\u03b7\u03bc\u03bf\u03c5\u03c2 \u03c6\u03bf\u03c1\u03b5\u03af\u03c2 (\u03c0.\u03c7. \u0395\u039b\u03a3\u03a4\u0391\u03a4, Eurostat", "tokens_used": 1236, "created_at": 9389.765, "ttl_seconds": 3600, "access_count": 0, "last_accessed": 9389.765}