b3\u03ae '\u03c0\u03c1\u03ce\u03c4\u03c9\u03bd \u03b4\u03b5\u03b4\u03bf\u03bc\u03ad\u03bd\u03c9\u03bd'.\",\n    \"\u0397 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03bf\u03c7\u03ae \u03c4\u03c9\u03bd \u03c3\u03c7\u03bf\u03bb\u03b5\u03af\u03c9\u03bd \u03a9\u03bd\u03ac\u03c3\u03b5\u03b9\u03c9\u03bd (C5) \u03ad\u03c7\u03b5\u03b9 \u03c7\u03b1\u03bc\u03b7\u03bb\u03ae \u03b2\u03b1\u03b8\u03bc\u03bf\u03bb\u03bf\u03b3\u03af\u03b1 \u03b5\u03bc\u03c0\u03b9\u03c3\u03c4\u03bf\u03c3\u03cd\u03bd\u03b7\u03c2 (0.75, status: weak) \u03ba\u03b1\u03b9 \u03b4\u03b5\u03bd \u03b5\u03c0\u03b1\u03bb\u03b7\u03b8\u03b5\u03cd\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03b5\u03cd\u03bf\u03c5\u03c3\u03b1 \u03c0\u03b7\u03b3\u03ae.\",\n    \"\u0394\u03b5\u03bd \u03b1\u03bd\u03b1\u03c6\u03ad\u03c1\u03b5\u03c4\u03b1\u03b9 \u03c4\u03bf \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c4\u03b9\u03ba\u03cc \u03ae \u03ba\u03b1\u03bd\u03bf\u03bd\u03b9\u03c3\u03c4\u03b9\u03ba\u03cc \u03c0\u03bb\u03b1\u03af\u03c3\u03b9\u03bf (\u03c0.\u03c7. GDPR, \u03b5\u03bb\u03bb\u03b7\u03bd\u03b9\u03ba\u03ae \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c3\u03af\u03b1 \u03b3\u03b9\u03b1 \u03b1\u03bd\u03b7\u03bb\u03af\u03ba\u03bf\u03c5\u03c2) \u03c0\u03bf\u03c5 \u03b4\u03b9\u03ad\u03c0\u03b5\u03b9 \u03c4\u03b7 \u03c7\u03c1\u03ae\u03c3\u03b7 AI \u03b1\u03c0\u03cc \u03bc\u03b1\u03b8\u03b7\u03c4\u03ad\u03c2.\",\n    \"\u0394\u03b5\u03bd \u03c5\u03c0\u03ac\u03c1\u03c7\u03bf\u03c5\u03bd \u03c3\u03c4\u03bf\u03b9\u03c7\u03b5\u03af\u03b1 \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03c4\u03c1\u03cc\u03c0\u03bf \u03b1\u03be\u03b9\u03bf\u03bb\u03cc\u03b3\u03b7\u03c3\u03b7\u03c2 \u03c4\u03b7\u03c2 \u03c0\u03b9\u03bb\u03bf\u03c4\u03b9\u03ba\u03ae\u03c2 \u03c6\u03ac\u03c3\u03b7\u03c2 \u03ae \u03c4\u03b1 \u03ba\u03c1\u03b9\u03c4\u03ae\u03c1\u03b9\u03b1 \u03b5\u03c0\u03b9\u03c4\u03c5\u03c7\u03af\u03b1\u03c2 \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03bf\u03b4\u03b7\u03b3\u03ae\u03c3\u03bf\u03c5\u03bd \u03c3\u03b5 \u03c0\u03b1\u03