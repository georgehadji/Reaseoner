# ═══════════════════════════════════════════════════════════════════════════════
# API Keys - NEVER commit this file with real values!
# ═══════════════════════════════════════════════════════════════════════════════

# ── RECOMMENDED: OpenRouter (unified access to 346+ models) ──────────────────
# Get key: https://openrouter.ai/keys
# Single key replaces all individual provider keys below.
# Use presets: or-ultra-budget, or-budget-plus, or-balanced ⭐, or-quality, or-max-quality
OPENROUTER_API_KEY=sk-or-v1-...

# ── Individual Provider Keys (still supported for direct API access) ──────────
# Only set these if NOT using OpenRouter, or for mixed setups.

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini - https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=...

# DeepSeek - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Mistral AI - https://console.mistral.ai/
MISTRAL_API_KEY=...

# xAI Grok - https://console.x.ai/
XAI_API_KEY=...

# Perplexity - https://www.perplexity.ai/
# Note: Search now routes through OpenRouter (uses OPENROUTER_API_KEY).
# Only needed if using Perplexity embeddings via neuro.yaml.
PERPLEXITY_API_KEY=pplx-...

# Alibaba Qwen - https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-...

# Moonshot Kimi - https://platform.moonshot.cn/
MOONSHOT_API_KEY=...

# ZhipuAI GLM - https://open.bigmodel.cn/
ZHIPUAI_API_KEY=...

# ═══════════════════════════════════════════════════════════════════════════════
# Admin & Security
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# Admin & Security
# ═══════════════════════════════════════════════════════════════════════════════

# Admin API key for administrative endpoints (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# CSRF token signing secret (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CSRF_SECRET=

# Deployment environment: development | production
# WARNING: Omitting this defaults CORS to development mode (insecure)
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════════════════════
# SearXNG Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# URL of the SearXNG instance used for web search.
# Auto-started on port 8888 by start_all.py via Docker Compose.
SEARXNG_URL=http://localhost:8888

# ═══════════════════════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Debug mode - MUST be false in production
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
SERVER_HOST=127.0.0.1

# Server port
SERVER_PORT=8003

# Uvicorn bind host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
# Use 127.0.0.1 for localhost-only development.
# Use 0.0.0.0 only when running inside a container or behind a reverse proxy.
UVICORN_HOST=127.0.0.1

# CORS origins — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8003,http://127.0.0.1:8003

# Frontend proxy target (Next.js API routes proxy to this URL)
# Only needed if backend runs on non-default port or different host
REASONER_API_URL=http://localhost:8003

# OpenRouter analytics headers (optional, used for rank tracking)
OPENROUTER_HTTP_REFERER=https://github.com/Reasoner
OPENROUTER_APP_TITLE=Reasoner

# ═══════════════════════════════════════════════════════════════════════════════
# Embedding & Reranking Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Cohere Rerank 4 Fast via OpenRouter — improves search result relevance
# Uses OPENROUTER_API_KEY (no separate key needed)
COHERE_RERANK_ENABLED=true
COHERE_RERANK_MODEL=cohere/rerank-4-fast

# Document Semantic Retrieval (Phase 4) — chunk + embed uploaded files
# Opt-in: set to true to enable semantic retrieval instead of verbatim injection
DOCUMENT_SEMANTIC_RETRIEVAL_ENABLED=false
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
DOCUMENT_MAX_CHUNKS_PER_FILE=500

# ═══════════════════════════════════════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════════════════════════════════════

# Requests per minute per client
RATE_LIMIT_PER_MINUTE=60

# Requests per hour per client
RATE_LIMIT_PER_HOUR=1000

# Burst size (short-term allowance)
RATE_LIMIT_BURST=10

# Shared state backend for rate limiter: memory | redis
# memory = unsafe for multi-worker deployments — use redis in production
RATE_LIMITER_MODE=memory

# Shared state backend for circuit breaker: memory | redis
# memory = unsafe for multi-worker deployments — use redis in production
CIRCUIT_BREAKER_MODE=memory

# ═══════════════════════════════════════════════════════════════════════════════
# SaaS Auth (Supabase + Local JWT fallback)
# ═══════════════════════════════════════════════════════════════════════════════

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local dev JWT (fallback when Supabase unavailable)
JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>

# Legacy Compatibility
ENABLE_LEGACY_API_KEY=false  # Set to true only for v1 API client backward compatibility

# ═══════════════════════════════════════════════════════════════════════════════
# Database & Cache
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (used for quota/auth persistence in SaaS mode)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reasoner
POSTGRES_PASSWORD=

# Asyncpg connection pool size
DB_POOL_SIZE=10

# Redis connection string (used for quota caching, rate limiting, session store)
REDIS_URL=redis://localhost:6379/0

# Resource limits
MEMORY_LIMIT_MB=1024
MEMORY_WARNING_MB=768
REQUEST_TIMEOUT_SECONDS=300

# Sentry tracing sample rate (0.0 = no traces, 1.0 = all traces)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Comma-separated list of trusted proxy IPs.
# Only used to parse X-Forwarded-For. Leave empty to disable.
TRUSTED_PROXIES=

# ═══════════════════════════════════════════════════════════════════════════════
# Stripe Billing
# ═══════════════════════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Frontend app URL (used for checkout redirects)
APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# Git Integration (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable Git integration
ORCHESTRATOR_GIT_ENABLED=false

# Commit strategy: after_each_task | after_phase | after_project | manual
ORCHESTRATOR_GIT_STRATEGY=manual

# Auto-push to remote (use with caution!)
ORCHESTRATOR_GIT_AUTO_PUSH=false
