# Development / local Caddyfile
# For production with auto HTTPS, see Caddyfile.prod

:80 {
    # Health check endpoint (bypass proxy)
    handle /api/health {
        reverse_proxy https://backend:8000 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # API routes → FastAPI
    handle /api/* {
        reverse_proxy https://backend:8000 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # WebSocket support
    handle /ws/* {
        reverse_proxy https://backend:8000 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # Everything else → Next.js
    handle {
        reverse_proxy https://frontend:3000 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }
}
