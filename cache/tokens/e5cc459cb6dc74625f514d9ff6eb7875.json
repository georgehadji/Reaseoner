4\u03b7\u03c4\u03b1 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03bf\u03c3\u03ad\u03b3\u03b3\u03b9\u03c3\u03b7\u03c2.\\n\\n\u03a3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03bc\u03b5 \u03c4\u03b1 \u03b4\u03b9\u03b1\u03b8\u03ad\u03c3\u03b9\u03bc\u03b1 \u03c3\u03c4\u03bf\u03b9\u03c7\u03b5\u03af\u03b1, \u03b7 \u03c0\u03b9\u03bb\u03bf\u03c4\u03b9\u03ba\u03ae \u03c6\u03ac\u03c3\u03b7 \u03be\u03b5\u03ba\u03af\u03bd\u03b7\u03c3\u03b5 \u03c0\u03c1\u03ce\u03c4\u03b1 \u03b1\u03c0\u03cc \u03c4\u03bf\u03c5\u03c2 \u03b5\u03ba\u03c0\u03b1\u03b9\u03b4\u03b5\u03c5\u03c4\u03b9\u03ba\u03bf\u03cd\u03c2 \u03c4\u03bf\u03bd \u0394\u03b5\u03ba\u03ad\u03bc\u03b2\u03c1\u03b9\u03bf \u03c4\u03bf\u03c5 2025 [Source: https://www.lifo.gr/now/greece/chatgpt-mpainei-sta-ellinika-sholeia-xekina-pilotiko-programma-se-20-gymnasia-kai-lykeia]. \u0397 \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ae \u03b1\u03c5\u03c4\u03ae \u03b4\u03b5\u03bd \u03b5\u03af\u03bd\u03b1\u03b9 \u03c4\u03c5\u03c7\u03b1\u03af\u03b1: \u03c0\u03c1\u03b9\u03bd \u03b5\u03ba\u03c4\u03b5\u03b8\u03bf\u03cd\u03bd \u03bf\u03b9 \u03bc\u03b1\u03b8\u03b7\u03c4\u03ad\u03c2 \u03c3\u03c4\u03bf \u03b5\u03c1\u03b3\u03b1\u03bb\u03b5\u03af\u03bf, \u03bf\u03b9 \u03af\u03b4\u03b9\u03bf\u03b9 \u03bf\u03b9 \u03b4\u03ac\u03c3\u03ba\u03b1\u03bb\u03bf\u03b9 \u03bf\u03c6\u03b5\u03af\u03bb\u03bf\u03c5\u03bd \u03bd\u03b1 \u03c4\u03bf \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03ae\u03c3\u03bf\u03c5\u03bd, \u03bd\u03b1 \u03c4\u03bf \u03b1\u03be\u03b9\u03bf\u03bb\u03bf\u03b3\u03ae\u03c3\u03bf\u03c5\u03bd \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c4\u03bf \u03b5\u03bd\u03c3\u03c9\u03bc\u03b1\u03c4\u03ce\u03c3\u03bf\u03c5\u03bd \u03c0\u03b1\u03b9\u03b4\u03b1\u03b3\u03c9\u03b3\u03b9\u03ba\u03ac \u03c3\u03c4\u03b7 \u03b4\u03b9\u03b4\u03b1\u03ba\u03c4\u03b9\u03ba\u03ae \u03c4\u03bf\u03c5\u03c2 \u03c0\u03c1\u03b1\u03ba\u03c4\u03b9\u03ba\u03ae. \u03a3\u03c4\u03b7 \u03c3\u03c5\u03bd\u03ad\u03c7\u03b5\u03b9\u03b1, \u03c4\u03bf\u03bd \u039c\u03ac\u03c1\u03c4\u03b9\u03bf \u03c4\u03bf\u03c5 2026, \u03c4\u03bf \u03c0\u03c1\u03cc\u03b3\u03c1\u03b1\u03bc\u03bc\u03b1 \u03c0\u03c1\u03bf\u03b2\u03bb\u03ad\u03c0\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03b5\u03c0\u03b5\u03ba\u03c4\u03b1\u03b8\u03b5\u03af \u03c3\u03c4\u03bf\u03c5\u03c2 \u03bc\u03b1\u03b8\u03b7\u03c4\u03ad\u03c2 \u03c4\u03b7\u03c2 \u0391' \u03ba\u03b1\u03b9 \u0392' \u039b\u03c5\u03ba\u03b5\u03af\u03bf\u03c5 [Source: https://www.lifo.gr/now/greece/chatgpt-mpainei-sta-ellinika-sholeia-xekina-pilotiko-programma-se-20-gymnasia-kai-lykeia].\\n\\n\u03a9\u03c2 \u03c0\u03c1\u03bf\u03c2 \u03c4\u03b7 \u03b3\u03b5\u03c9\u03b3\u03c1\u03b1\u03c6\u03af\u03b1 \u03c4\u03bf\u03c5 \u03c0\u03b5\u03b9\u03c1\u03ac\u03bc\u03b1\u03c4\u03bf\u03c2, \u03c4\u03bf \u03c0\u03c1\u03cc\u03b3\u03c1\u03b1\u03bc\u03bc\u03b1 \u03b4\u03b5\u03bd \u03b1\u03c0\u03b5\u03c5\u03b8\u03cd\u03bd\u03b5\u03c4\u03b1\u03b9 \u03c3\u03b5 \u03c4\u03c5\u03c7\u03b1\u03af\u03b1 \u03b4\u03b5\u03af\u03b3\u03bc\u03b1 \u03c3\u03c7\u03bf\u03bb\u03b5\u03af\u03c9\u03bd. \u03a3\u03c5\u03b3\u03ba\u03b5\u03ba\u03c1\u03b9\u03bc\u03ad\u03bd\u03b1, \u03b8\u03b1 \u03bb\u03ac\u03b2\u03bf\u03c5\u03bd \u03bc\u03ad\u03c1\u03bf\u03c2 14 \u03c0\u03c1\u03cc\u03c4\u03c5\u03c0\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b5\u03b9\u03c1\u03b1\u03bc\u03b1\u03c4\u03b9\u03ba\u03ac \u03bb\u03cd\u03ba\u03b5\u03b9\u03b1 [Source: https://www.lifo.gr/now/greece/chatgpt-mpainei-sta-ellinika-sholeia-xekina-pilotiko-programma-se-20-gymnasia-kai-lykeia], \u03b9\u03b4\u03c1\u03cd\u03bc\u03b1\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03ae\u03b4\u03b7 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03bf\u03cd\u03bd \u03c9\u03c2 \u03b5\u03c1\u03b3\u03b1\u03c3\u03c4\u03ae\u03c1\u03b9\u03b1 \u03b5\u03ba\u03c0\u03b1\u03b9\u03b4\u03b5\u03c5\u03c4\u03b9\u03ba\u03ae\u03c2 \u03ba\u03b1\u03b9\u03bd\u03bf\u03c4\u03bf\u03bc\u03af\u03b1\u03c2. \u03a0\u03b1\u03c1\u03ac\u03bb\u03bb\u03b7\u03bb\u03b1, \u03c3\u03c4\u03bf \u03b5\u03b3\u03c7\u03b5\u03af\u03c1\u03b7\u03bc\u03b1 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03c5\u03bd 6 \u03c3\u03c7\u03bf\u03bb\u03b5\u03af\u03b1 \u03c4\u03bf\u03c5 \u03b4\u03b9\u03ba\u03c4\u03cd\u03bf\u03c5 \u03a9\u03bd\u03ac\u03c3\u03b5\u03b9\u03c9\u03bd, \u03c4\u03b1 \u03bf\u03c0\u03bf\u03af\u03b1 \u03b5\u03af\u03c7\u03b1\u03bd \u03ae\u03b4\u03b7 \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03b5\u03b9 \u03c4\u03b7 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b1 \u03c4\u03bf\u03c5\u03c2 \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03a3\u03b5\u03c0\u03c4\u03ad\u03bc\u03b2\u03c1\u03b9\u03bf [Source: https://www.lifo.gr/now/greece/chatgpt-mpainei-sta-ellinika-sholeia-xekina-pilotiko-programma-se-20-gymnasia-kai-lykeia].\\n\\n\u03a4\u03bf \u03b5\u03c1\u03ce\u03c4\u03b7\u03bc\u03b1 \u03c0\u03bf\u03c5 \u03c0\u03b1\u03c1\u03b1\u03bc\u03ad\u03bd\u03b5\u03b9 \u03b1\u03bd\u03bf\u03b9\u03c7\u03c4\u03cc \u03b5\u03af\u03bd\u03b1\u03b9 \u03c4\u03b9 \u03b3\u03af\u03bd\u03b5\u03c4\u03b1\u03b9 \u03bc\u03b5\u03c4\u03ac. \u03a5\u03c0\u03ac\u03c1\u03c7\u03b5\u03b9 \u03b7 \u03c0\u03c1\u03bf\u03bf\u03c0\u03c4\u03b9\u03ba\u03ae \u2014 \u03cc\u03c7\u03b9 \u03b1\u03ba\u03cc\u03bc\u03b1 \u03b5\u03c0\u03af\u03c3\u03b7\u03bc\u03b7 \u03b1\u03c0\u03cc\u03c6\u03b1\u03c3\u03b7 \u2014 \u03c4\u03b7\u03c2 \u03c0\u03b1\u03bd\u03b5\u03bb\u03bb\u03b1\u03b4\u03b9\u03ba\u03ae\u03c2 \u03b5\u03c6\u03b1\u03c1\u03bc\u03bf\u03b3\u03ae\u03c2 \u03b1\u03c0\u03cc \u03c4\u03bf \u03c3\u03c7\u03bf\u03bb\u03b9\u03ba\u03cc \u03ad\u03c4\u03bf\u03c2 2026-2027 [Source: https://www.lifo.gr/now/greece/chatgpt-mpainei-sta-ellinika-sholeia-xekina-pilotiko-programma-se-20-gymnasia-kai-lykeia]. \u0391\u03bd \u03c4\u03b1 \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03ad\u03c3\u03bc\u03b1\u03c4\u03b1 \u03c4\u03bf\u03c5 \u03c0\u03b9\u03bb\u03cc\u03c4\u03bf\u03c5 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b5\u03bd\u03b8\u03b1\u03c1\u03c1\u03c5\u03bd\u03c4\u03b9\u03ba\u03ac, \u03b7 \u0395\u03bb\u03bb\u03ac\u03b4\u03b1 \u03b8\u03b1 \u03bc\u03c0\u03bf\u03c1\u03bf\u03cd\u03c3\u03b5 \u03bd\u03b1 \u03b1\u03c0\u03bf\u03c4\u03b5\u