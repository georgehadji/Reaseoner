# Production Caddyfile with automatic HTTPS
# Critical Enhancement 5.8: auto_https is ON (default) in production

yourdomain.com {
    # Health check endpoint
    handle /api/health {
        reverse_proxy backend:8000
    }

    # API routes → FastAPI
    handle /api/* {
        reverse_proxy backend:8000
    }

    # WebSocket support
    handle /ws/* {
        reverse_proxy backend:8000
    }

    # Everything else → Next.js
    handle {
        reverse_proxy frontend:3000
    }
}
