# Development / local Caddyfile
# For production with auto HTTPS, see Caddyfile.prod

:80 {
    # Health check endpoint (bypass proxy)
    handle /api/health {
        reverse_proxy backend:8000
    }

    # API routes → FastAPI
    handle /api/* {
        reverse_proxy backend:8000
    }

    # WebSocket support
    handle /ws/* {
        reverse_proxy backend:8000
    }

    # Everything else → Next.js
    handle {
        reverse_proxy frontend:3000
    }
}
