u03b1\u03c5\u03c4\u03bf\u03c3\u03c5\u03bc\u03c0\u03cc\u03bd\u03b9\u03b1 \u03c9\u03c2 \u03b5\u03bd\u03b1\u03bb\u03bb\u03b1\u03ba\u03c4\u03b9\u03ba\u03ae \u03c4\u03b7\u03c2 \u03b1\u03c5\u03c4\u03bf\u03c0\u03c1\u03bf\u03c3\u03c4\u03b1\u03c3\u03af\u03b1\u03c2, 5) \u0394\u03bf\u03ba\u03af\u03bc\u03b1\u03b6\u03b5 \u03c3\u03c4\u03b1\u03b4\u03b9\u03b1\u03ba\u03ac \u03c4\u03b7\u03bd \u03ad\u03ba\u03b8\u03b5\u03c3\u03b7 \u03c3\u03b5 \u03b5\u03c5\u03ac\u03bb\u03c9\u03c4\u03b5\u03c2 \u03ba\u03b1\u03c4\u03b1\u03c3\u03c4\u03ac\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b5\u03c0\u03b1\u03bd\u03b1\u03c0\u03c1\u03bf\u03b3\u03c1\u03b1\u03bc\u03bc\u03b1\u03c4\u03af\u03c3\u03b5\u03b9\u03c2 \u03c4\u03b9\u03c2 \u03b1\u03bd\u03c4\u03b9\u03b4\u03c1\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c3\u03bf\u03c5.", "key_insights": ["\u039f\u03b9 \u03ac\u03bc\u03c5\u03bd\u03b5\u03c2 \u03b4\u03b7\u03bc\u03b9\u03bf\u03c5\u03c1\u03b3\u03ae\u03b8\u03b7\u03ba\u03b1\u03bd \u03b3\u03b9\u03b1 \u03bb\u03cc\u03b3\u03bf\u03c5\u03c2 \u03c0\u03c1\u03bf\u03c3\u03c4\u03b1\u03c3\u03af\u03b1\u03c2 - \u03b7 \u03b1\u03bd\u03b1\u03b3\u03bd\u03ce\u03c1\u03b9\u03c3\u03ae \u03c4\u03bf\u03c5\u03c2 \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af \u03c4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03b2\u03ae\u03bc\u03b1 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03bc\u03b5\u03c4\u03b1\u03c4\u03c1\u03bf\u03c0\u03ae \u03c4\u03bf\u03c5\u03c2", "\u0397 \u03b5\u03b9\u03bb\u03b9\u03ba\u03c1\u03af\u03bd\u03b5\u03b9\u03b1 \u03b1\u03c0\u03b1\u03b9\u03c4\u03b5\u03af \u03b1\u03c3\u03c6\u03ac\u03bb\u03b5\u03b9\u03b1: \u03b4\u03b7\u03bc\u03b9\u03bf\u03cd\u03c1\u03b3\u03b7\u03c3\u03b5 \u03ad\u03bd\u03b1 \u03b5\u03c3\u03c9\u03c4\u03b5\u03c1\u03b9\u03ba\u03cc \u03c0\u03b5\u03c1\u03b9\u03b2\u03ac\u03bb\u03bb\u03bf\u03bd \u03b1\u03c0\u03bf\u03b4\u03bf\u03c7\u03ae\u03c2 \u03c0\u03c1\u03b9\u03bd \u03b6\u03b7\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03b5\u03b1\u03c5\u03c4\u03cc \u03c3\u03bf\u03c5 \u03bd\u03b1 \u03ba\u03b1\u03c4\u03b1\u03c1\u03b3\u03ae\u03c3\u03b5\u03b9 \u03c4\u03b9\u03c2 \u03ac\u03bc\u03c5\u03bd\u03b5\u03c2", "\u0397 \u03c0\u03c1\u03bf\u03bf\u03b4\u03b5\u03c5\u03c4\u03b9\u03ba\u03ae \u03ad\u03ba\u03b8\u03b5\u03c3\u03b7 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b5\u03af \u03c9\u03c2 '\u03b1\u03bd\u03c4\u03b9\u03b4\u03bf\u03c4\u03bf\u03c0\u03bf\u03af\u03b7\u03c3\u03b7' - \u03bf \u03b5\u03b3\u03ba\u03ad\u03c6\u03b1\u03bb\u03bf\u03c2 \u03bc\u03b1\u03b8\u03b1\u03af\u03bd\u03b5\u03b9 \u03cc\u03c4\u03b9 \u03bf\u03b9 \u03c0\u03b1\u03bb\u03b9\u03ad\u03c2 \u03b1\u03c0\u03b5\u03b9\u03bb\u03ad\u03c2 \u03b4\u03b5\u03bd \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03bd \u03c0\u03bb\u03ad\u03bf\u03bd"], "model_used": ""}, {"perspective": "destructive", "content": "\u0397 \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03b1 \u03bd\u03b1 \u03b5\u03be\u03b7\u03b3\u03b7\u03b8\u03bf\u03cd\u03bd \u03bf\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af \u03c4\u03bf\u03c5 \u03b5\u03b3\u03ce \u03bc\u03ad\u03c3\u03c9 \u03c4\u03b7\u03c2 \u03c3\u03cd\u03b3\u03ba\u03c1\u03b9\u03c3\u03b7\u03c2 \u03bc\u03b5 \u03c4\u03bf\u03bd \u03a6\u03c1\u03cc\u03b9\u03bd\u03c4 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b5\u03b3\u03b3\u03b5\u03bd\u03ce\u03c2 \u03c0\u03c1\u03bf\u03b2\u03bb\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03ae, \u03ba\u03b1\u03b8\u03ce\u03c2 \u03c5\u03c0\u03bf\u03b8\u03ad\u03c4\u03b5\u03b9 \u03cc\u03c4\u03b9 \u03c4\u03bf \u03b5\u03b3\u03ce \u03b5\u03af\u03bd\u03b1\u03b9 \u03bc\u03b9\u03b1 \u03c3\u03c4\u03b1\u03b8\u03b5\u03c1\u03ae, \u03b1\u03bd\u03c4\u03b9\u03ba\u03b5\u03b9\u03bc\u03b5\u03bd\u03b9\u03ba\u03ae \u03bf\u03bd\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03b1\u03bd\u03b1\u03bb\u03c5\u03b8\u03b5\u03af \u03c9\u03c2 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2 \u2014 \u03bc\u03b9\u03b1 \u03c0\u03b1\u03c1\u03b1\u03b4\u03bf\u03c7\u03ae \u03c0\u03bf\u03c5 \u03b1\u03bd\u03c4\u03b9\u03ba\u03c1\u03bf\u03cd\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03c3\u03cd\u03b3\u03c7\u03c1\u03bf\u03bd\u03b5\u03c2 \u03c8\u03c5\u03c7\u03bf\u03bb\u03bf\u03b3\u03b9\u03ba\u03ad\u03c2, \u03c6\u03b9\u03bb\u03bf\u03c3\u03bf\u03c6\u03b9\u03ba\u03ad\u03c2 \u03ba\u03b1\u03b9 \u03bd\u03b5\u03c5\u03c1\u03bf\u03b5\u03c0\u03b9\u03c3\u03c4\u03b7\u03bc\u03bf\u03bd\u03b9\u03ba\u03ad\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b5\u03b3\u03b3\u03af\u03c3\u03b5\u03b9\u03c2. \u039f \u03a6\u03c1\u03cc\u03b9\u03bd\u03c4 \u03bf \u03af\u03b4\u03b9\u03bf\u03c2 \u03c0\u03c1\u03bf\u03c3\u03ad\u03b3\u03b3\u03b9\u03b6\u03b5 \u03c4\u03bf \u03b5\u03b3\u03ce \u03c9\u03c2 \u03b4\u03c5\u03bd\u03b1\u03bc\u03b9\u03ba\u03ae \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b1, \u03cc\u03c7\u03b9 \u03c9\u03c2 \u03c3\u03c4\u03b1\u03c4\u03b9\u03ba\u03cc '\u03c0\u03c1\u03ac\u03b3\u03bc\u03b1', \u03ba\u03b1\u03b9 \u03b7 \u03b1\u03c0\u03bb\u03bf\u03ca\u03ba\u03ae \u03b5\u03be\u03af\u03c3\u03c9\u03c3\u03ae \u03c4\u03bf\u03c5 \u03bc\u03b5 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2 \u03c5\u03c0\u03bf\u03bd\u03bf\u03bc\u03b5\u03cd\u03b5\u03b9 \u03c4\u03b7\u03bd \u03c0\u03bf\u03bb\u03c5\u03c0\u03bb\u03bf\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03b7\u03c2 \u03c5\u03c0\u03bf\u03ba\u03b5\u03b9\u03bc\u03b5\u03bd\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2. \u0395\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd, \u03b7 \u03b9\u03b4\u03ad\u03b1 \u03cc\u03c4\u03b9 \u03ba\u03ac\u03c0\u03bf\u03b9\u03bf\u03c2 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 '\u03be\u03b5\u03c0\u03b5\u03c1\u03ac\u03c3\u03b5\u03b9' \u03c4\u03bf \u03b5\u03b3\u03ce \u03c4\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b3\u03af\u03bd\u03b5\u03b9 '\u03b5\u03bb\u03b9\u03ba\u03c1\u03b9\u03bd\u03ae\u03c2' \u03c0\u03c1\u03bf\u03c2 \u03c4\u03bf\u03bd \u03b5\u03b1\u03c5\u03c4\u03cc \u03c4\u03bf\u03c5 \u03c3\u03c4\u03b7\u03c1\u03af\u03b6\u03b5\u03c4\u03b1\u03b9 \u03c3\u03b5 \u03bc\u03b9\u03b1 \u03c8\u03b5\u03c5\u03b4\u03b1\u03af\u03c3\u03b8\u03b7\u03c3\u03b7 \u03b1\u03c5\u03c4\u03bf\u03b4\u03b9\u03b1\u03c6\u03ac\u03bd\u03b5\u03b9\u03b1\u03c2: \u03c4\u03bf \u03b5\u03b3\u03ce \u03b5\u03af\u03bd\u03b1\u03b9 \u03b5\u03b3\u03b3\u03b5\u03bd\u03ce\u03c2 \u03b4\u03b9\u03b1\u03bc\u03bf\u03c1\u03c6\u03c9\u03bc\u03ad\u03bd\u03bf \u03b1\u03c0\u03cc \u03b1\u03c3\u03c5\u03bd\u03b5\u03af\u03b4\u03b7\u03c4\u03b5\u03c2 \u03b4\u03c5\u03bd\u03ac\u03bc\u03b5\u03b9\u03c2, \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ad\u03c2 \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ad\u03c2 \u03ba\u03b1\u03b9 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b9\u03ba\u03ad\u03c2 \u03b4\u03bf\u03bc\u03ad\u03c2 \u03c0\u03bf\u03c5 \u03b4\u03b5\u03bd \u03b5\u03af\u03bd\u03b1\u03b9 \u03c5\u03c0\u03cc \u03c4\u03bf\u03bd \u03ac\u03bc\u03b5\u03c3\u03bf \u03ad\u03bb\u03b5\u03b3\u03c7\u03cc \u03c4\u03bf\u03c5. \u0397 \u03c0\u03af\u03c3\u03c4\u03b7 \u03c3\u03c4\u03b7 \u03b4\u03c5\u03bd\u03b1\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 '\u03be\u03b5\u03c0\u03b5\u03c1\u03ac\u03c3\u03bc\u03b1\u03c4\u03bf\u03c2' \u03c4\u03bf\u03c5 \u03b5\u03b3\u03ce \u03bc\u03ad\u03c3\u03c9 \u03b1\u03c5\u03c4\u03bf-\u03b1\u03bd\u03ac\u03bb\u03c5\u03c3\u03b7\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b5\u03af\u03c4\u03b5 \u03bd\u03b1\u03c1\u03ba\u03b9\u03c3\u03c3\u03b9\u03c3\u03c4\u03b9\u03ba\u03ae (\u03c0\u03b9\u03c3\u03c4\u03b5\u03cd\u03bf\u03bd\u03c4\u03b1\u03c2 \u03cc\u03c4\u03b9 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03ba\u03b1\u03bd\u03b5\u03af\u03c2 \u03bd\u03b1 \u03ad\u03c7\u03b5\u03b9 \u03c0\u03bb\u03ae\u03c1\u03b7 \u03c0\u03c1\u03cc\u03c3\u03b2\u03b1\u03c3\u03b7 \u03c3\u03c4\u03bf \u03b5\u03c3\u03c9\u03c4\u03b5\u03c1\u03b9\u03ba\u03cc \u03c4\u03bf\u03c5 \u03ba\u03cc\u03c3\u03bc\u03bf) \u03b5\u03af\u03c4\u03b5 \u03b1\u03c6\u03b5\u03bb\u03ae\u03c2 (\u03b1\u03b3\u03bd\u03bf\u03ce\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c1\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2 \u03c4\u03b7\u03c2 \u03b1\u03c5\u03c4\u03bf\u03b3\u03bd\u03c9\u03c3\u03af\u03b1\u03c2). \u03a4\u03ad\u03bb\u03bf\u03c2, \u03bf\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af \u03ac\u03bc\u03c5\u03bd\u03b1\u03c2 \u03b4\u03b5\u03bd \u03b5\u03af\u03bd\u03b1\u03b9 \u03b5\u03bc\u03c0\u03cc\u03b4\u03b9\u03b1 \u03c0\u03c1\u03bf\u03c2 \u03b1\u03c0\u03bf\u03bc\u03ac\u03ba\u03c1\u03c5\u03bd\u03c3\u03b7, \u03b1\u03bb\u03bb\u03ac \u03b8\u03b5\u03bc\u03b5\u03bb\u03b9\u03ce\u03b4\u03b7 \u03c3\u03c5\u03c3\u03c4\u03b1\u03c4\u03b9\u03ba\u03ac \u03c4\u03b7\u03c2 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae\u03c2 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b1\u03c2 \u2014 \u03c7\u03c9\u03c1\u03af\u03c2 \u03b1\u03c5\u03c4\u03bf\u03cd\u03c2, \u03b7 \u03c8\u03c5\u03c7\u03ae \u03b4\u03b5\u03bd \u03b8\u03b1 \u03bc\u03c0\u03bf\u03c1\u03bf\u03cd\u03c3\u03b5 \u03bd\u03b1 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03ae\u03c3\u03b5\u03b9. \u0397 \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03b1 \u03bd\u03b1 \u03c4\u03bf\u03c5\u03c2 '\u03be\u03b5\u03c0\u03b5\u03c1\u03ac\u03c3\u03b5\u03b9' \u03ba\u03ac\u03c0\u03bf\u03b9\u03bf\u03c2 \u03bf\u03b4\u03b7\u03b3\u03b5\u03af \u03cc\u03c7\u03b9 \u03c3\u03b5 \u03b5\u03bb\u03b9\u03ba\u03c1\u03af\u03bd\u03b5\u03b9\u03b1, \u03b1\u03bb\u03bb\u03ac \u03c3\u03b5 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae \u03b1\u03c0\u03bf\u03c3\u03c4\u03b1\u03b8\u03b5\u03c1\u03bf\u03c0\u03bf\u03af\u03b7\u03c3\u03b7 \u03ae \u03c8\u03b5\u03c5\u03b4\u03b1\u03af\u03c3\u03b8\u03b7\u03c3\u03b7 \u03b1\u03c0\u03bf\u03ba\u03ac\u03bb\u03c5\u03c8\u03b7\u03c2.", "key_insights": ["\u0397 \u03ad\u03bd\u03bd\u03bf\u03b9\u03b1 \u03c4\u03bf\u03c5 \u03b5\u03b3\u03ce \u03c9\u03c2 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd \u03b5\u03af\u03bd\u03b1\u03b9 \u03b1\u03bd\u03b1\u03c7\u03c1\u03bf\u03bd\u03b9\u03c3\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03b9 \u03b1\u03bd\u03b1\u03b3\u03c9\u03b3\u03b9\u03c3\u03c4\u03b9\u03ba\u03ae.", "\u0397 \u03b1\u03c5\u03c4\u03bf-\u03b5\u03bb\u03b9\u03ba\u03c1\u03af\u03bd\u03b5\u03b9\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03bc\u03b9\u03b1 \u03b1\u03bd\u03ad\u03c6\u03b9\u03ba\u03c4\u03b7 \u03b9\u03b4\u03ad\u03b1 \u03bb\u03cc\u03b3\u03c9 \u03c4\u03b7\u03c2 \u03b1\u03c3\u03c5\u03bd\u03b5\u03af\u03b4\u03b7\u03c4\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac \u03b5\u03bd\u03c3\u03c9\u03bc\u03b1\u03c4\u03c9\u03bc\u03ad\u03bd\u03b7\u03c2 \u03c6\u03cd\u03c3\u03b7\u03c2 \u03c4\u03bf\u03c5 \u03b5\u03b3\u03ce.", "\u039f\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af \u03ac\u03bc\u03c5\u03bd\u03b1\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b1\u03c0\u03b1\u03c1\u03b1\u03af\u03c4\u03b7\u03c4\u03bf\u03b9, \u03cc\u03c7\u03b9 \u03b5\u03bc\u03c0\u03cc\u03b4\u03b9\u03b1 \u2014 \u03b7 \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03b1 \u03c4\u03b7\u03c2 \u03b5\u03be\u03ac\u03bb\u03b5\u03b9\u03c8\u03ae\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03b1\u03c0\u03b5\u03b9\u03bb\u03b5\u03af \u03c4\u03b7\u03bd \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae \u03b9\u03c3\u03bf\u03c1\u03c1\u03bf\u03c0\u03af\u03b1.", "\u0397 \u03c0\u03c1\u03bf\u03c3\u03ad\u03b3\u03b3\u03b9\u03c3\u03b7 \u03b5\u03ba\u03c6\u03c1\u03ac\u03b6\u03b5\u03b9 \u03bd\u03b1\u03c1\u03ba\u03b9\u03c3\u03c3\u03b9\u03c3\u03c4\u03b9\u03ba\u03ae \u03c0\u03af\u03c3\u03c4\u03b7 \u03c3\u03c4\u03b7 \u03b4\u03c5\u03bd\u03b1\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c0\u03bb\u03ae\u03c1\u03bf\u03c5\u03c2 \u03b1\u03c5\u03c4\u03bf-\u03ba\u03b1\u03c4\u03b1\u03bd\u03cc\u03b7\u03c3\u03b7\u03c2, \u03b7 \u03bf\u03c0\u03bf\u03af\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c8\u03b5\u03c5\u03b4\u03b1\u03af\u03c3\u03b8\u03b7\u03c3\u03b7."], "model_used": ""}, {"perspective": "systemic", "content": "\u039f\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af \u03ac\u03bc\u03c5\u03bd\u03b1\u03c2 \u03c4\u03bf\u03c5 \u03b5\u03b3\u03ce \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03bc\u03b5 \u03c4\u03b7 \u03b8\u03b5\u03c9\u03c1\u03af\u03b1 \u03c4\u03bf\u03c5 \u03a6\u03c1\u03cc\u03b9\u03bd\u03c4 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03bf\u03cd\u03bd \u03c9\u03c2 \u03b1\u03c5\u03c4\u03bf\u03c1\u03c1\u03cd\u03b8\u03bc\u03b9\u03c3\u03b7 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae\u03c2 \u03b9\u03c3\u03bf\u03c1\u03c1\u03bf\u03c0\u03af\u03b1\u03c2. \u03a3\u03b5 \u03c3\u03c5\u03c3\u03c4\u03b7\u03bc\u03b9\u03ba\u03cc \u03b5\u03c0\u03af\u03c0\u03b5\u03b4\u03bf, \u03b1\u03c5\u03c4\u03bf\u03af \u03bf\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af (\u03b1\u03c0\u03cc\u03c1\u03c1\u03b9\u03c8\u03b7, \u03c0\u03b1\u03c1\u03b1\u03bc\u03cc\u03c1\u03c6\u03c9\u03c3\u03b7, \u03bc\u03b5\u03c4\u03b1\u03c4\u03cc\u03c0\u03b9\u03c3\u03b7, \u03ba\u03bb\u03c0.) \u03b4\u03b7\u03bc\u03b9\u03bf\u03c5\u03c1\u03b3\u03bf\u03cd\u03bd \u03b1\u03bb\u03c5\u03c3\u03b9\u03b4\u03c9\u03c4\u03ad\u03c2 \u03b1\u03bd\u03c4\u03b9\u03b4\u03c1\u03ac\u03c3\u03b5\u03b9\u03c2. \u0397 \u03b1\u03c1\u03c7\u03b9\u03ba\u03ae \u03ac\u03bc\u03c5\u03bd\u03b1 (1\u03b7 \u03c4\u03ac\u03be\u03b7\u03c2) \u03c0\u03c1\u03bf\u03c3\u03c4\u03b1\u03c4\u03b5\u03cd\u03b5\u03b9 \u03c4\u03bf \u03b5\u03b3\u03ce \u03b1\u03c0\u03cc \u03b4\u03c5\u03c3\u03ac\u03c1\u03b5\u03c3\u03c4\u03b5\u03c2 \u03c3\u03c5\u03bd\u03b1\u03b9\u03c3\u03b8\u03ae\u03bc\u03b1\u03c4\u03b1, \u03b1\u03bb\u03bb\u03ac \u03c0\u03c1\u03bf\u03ba\u03b1\u03bb\u03b5\u03af \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03b5\u03cd\u03bf\u03bd\u03c4\u03b5\u03c2 (2\u03b7\u03c2 \u03c4\u03ac\u03be\u03b7\u03c2) \u03c3\u03c5\u03bd\u03b5\u03c0\u03b1\u03b3\u03c9\u03b3\u03ad\u03c2 \u03cc\u03c0\u03c9\u03c2 \u03c0\u03b1\u03c1\u03b1\u03c0\u03bf\u03af\u03b7\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2, \u03b1\u03c0\u03bf\u03bc\u03cc\u03bd\u03c9\u03c3\u03b7 \u03ae \u03b5\u03be\u03c9\u03c4\u03b5\u03c1\u03af\u03ba\u03b5\u03c5\u03c3\u03b7. \u03a3\u03b5 \u03c4\u03c1\u03af\u03c4\u03bf \u03b5\u03c0\u03af\u03c0\u03b5\u03b4\u03bf, \u03b1\u03c5\u03c4\u03bf\u03af \u03bf\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03b9 \u03b4\u03b9\u03b1\u03bc\u03bf\u03c1\u03c6\u03ce\u03bd\u03bf\u03c5\u03bd \u03bc\u03cc\u03bd\u03b9\u03bc\u03b1 \u03bc\u03bf\u03c4\u03af\u03b2\u03b1 \u03c3\u03c5\u03bc\u03c0\u03b5\u03c1\u03b9\u03c6\u03bf\u03c1\u03ac\u03c2, \u03b5\u03c0\u03b7\u03c1\u03b5\u03ac\u03b6\u03bf\u03c5\u03bd \u03c4\u03b9\u03c2 \u03c3\u03c7\u03ad\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c1\u03af\u03b6\u03bf\u03c5\u03bd \u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03ae \u03b1\u03bd\u03ac\u03c0\u03c4\u03c5\u03be\u03b7.", "key_insights": ["\u039f\u03b9 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03bf\u03af \u03ac\u03bc\u03c5\u03bd\u03b1\u03c2, \u03b1\u03bd \u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03c3\u03c4\u03b1\u03c4\u03b5\u03c5\u03c4\u03b9\u03ba\u03bf\u03af \u03b1\u03c1\u03c7\u03b9\u03ba\u03ac, \u03b4\u03b7\u03bc\u03b9\u03bf\u03c5\u03c1\u03b3\u03ae\u03c3\u03bf\u03c5\u03bd \u03b5\u03c3\u03c9\u03c4\u03b5\u03c1\u03b9\u03ba\u03ae \u03b1\u03c3\u03c5\u03bc\u03b2\u03b1\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03c4\u03bf\u03c5 \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03bf\u03cd \u03b5\u03b1\u03c5\u03c4\u03bf\u03cd \u03ba\u03b1\u03b9 \u03c4\u03bf\u03c5 \u03b9\u03b4\u03b5\u03b1\u03c4\u03bf\u03cd \u03b5\u03b1\u03c5\u03c4\u03bf\u03cd, \u03bf\u03b4\u03b7\u03b3\u03ce\u03bd\u03c4\u03b1\u03c2 \u03c3\u03b5 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae \u03b4\u03c5\u03c3\u03c6\u03bf\u03c1\u03af\u03b1 \u03c3\u03b5 \u03bc\u03b1\u03ba\u03c1\u03bf\u03c0\u03c1\u03cc\u03b8\u03b5\u03c3\u03bc\u03b7 \u03c0\u03c1\u03bf\u03bf\u03c0\u03c4\u03b9\u03ba\u03ae", "\u0397 \u03b5\u03be\u03b5\u03c1\u03b5\u03cd\u03bd\u03b7\u03c3\u03b7 \u03c4\u03c9\u03bd \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03c3\u03bc\u03ce\u03bd \u03ac\u03bc\u03c5\u03bd\u03b1\u03c2 \u03c7\u03c9\u03c1\u03af\u03c2 \u03b5\u03b9\u03bb\u03b9\u03ba\u03c1\u03af\u03bd\u03b5\u03b9\u03b1 \u03b5\u